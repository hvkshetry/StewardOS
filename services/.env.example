# StewardOS services environment template
# Copy to .env and fill in real values: cp .env.example .env

# PostgreSQL
POSTGRES_PASSWORD=change-me-strong-password

# Vaultwarden
VAULTWARDEN_DOMAIN=https://vault.example.com
VAULTWARDEN_SIGNUPS_ALLOWED=false
VAULTWARDEN_ADMIN_TOKEN=change-me-generate-with-openssl-rand-base64-48

# Paperless-ngx
PAPERLESS_SECRET_KEY=change-me-generate-with-openssl-rand-base64-48

# Ghostfolio
GHOSTFOLIO_ACCESS_TOKEN_SALT=change-me-generate-with-openssl-rand-base64-32
GHOSTFOLIO_JWT_SECRET_KEY=change-me-generate-with-openssl-rand-base64-32
GHOSTFOLIO_PROCESSOR_GATHER_ASSET_PROFILE_CONCURRENCY=1
GHOSTFOLIO_PROCESSOR_GATHER_HISTORICAL_MARKET_DATA_CONCURRENCY=1

# Grocy
GROCY_API_KEY=change-me-generate-from-grocy-settings-api-keys

# wger
WGER_SECRET_KEY=change-me-generate-with-openssl-rand-base64-48
WGER_API_TOKEN=change-me-generate-from-wger-user-profile-api-key

# Oura
OURA_CLIENT_ID=change-me-oura-oauth-client-id
OURA_CLIENT_SECRET=change-me-oura-oauth-client-secret

# Apple Health
APPLE_HEALTH_EXPORT_DIR=/opt/stewardos/data/apple-health

# Directus + graph services
ESTATE_DB_PASSWORD=change-me-estate-db-password
FINANCE_DB_PASSWORD=change-me-finance-db-password
DIRECTUS_SECRET=change-me-generate-with-openssl-rand-base64-32
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-me-directus-admin-password

# n8n
N8N_DB_PASSWORD=change-me-n8n-db-password
N8N_AUTH_USER=admin
N8N_AUTH_PASSWORD=change-me-n8n-auth-password

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=change-me-tunnel-token-from-cloudflare-dashboard
