# Plane PM — environment variables
# Copy to services/.env and fill in values

# ── Core Secrets ──
PLANE_SECRET_KEY=           # Django secret key (generate: python3 -c "import secrets; print(secrets.token_urlsafe(64))")
PLANE_MACHINE_SIGNATURE=    # Instance identifier (generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))")

# ── MinIO (S3-compatible storage) ──
PLANE_MINIO_ROOT_USER=plane
PLANE_MINIO_ROOT_PASSWORD=  # generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# ── RabbitMQ ──
PLANE_RABBITMQ_USER=plane
PLANE_RABBITMQ_PASSWORD=    # generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# ── Plane MCP Server (agent access) ──
PLANE_API_TOKEN=            # Personal Access Token from Plane admin UI
PLANE_BASE_URL=http://localhost:8082
PLANE_WEBHOOK_SECRET=       # HMAC secret for webhook signatures (generate: python3 -c "import secrets; print(secrets.token_hex(32))")
