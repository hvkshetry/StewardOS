# Family Office Mail Worker environment template
SERVICE_HOST=127.0.0.1
SERVICE_PORT=8312
LOG_LEVEL=INFO

WORKER_SHARED_SECRET=replace-with-long-random-secret
GOOGLE_CREDENTIALS_PATH=/opt/stewardos/agent-configs/.shared-google-creds-agent-rw/credentials.json
GOOGLE_TOKEN_PATH=/opt/stewardos/agent-configs/.shared-google-creds-agent-rw/token.json
GOOGLE_PUBSUB_TOPIC=projects/your-project/topics/gmail-push
AGENT_EMAIL=agent.mailbox@example.com

ALLOWED_SENDERS=["owner1@example.com","owner2@example.com"]

ALIAS_PERSONA_MAP={"cos":"/opt/stewardos/agent-configs/chief-of-staff","estate":"/opt/stewardos/agent-configs/estate-counsel","hc":"/opt/stewardos/agent-configs/household-comptroller","hd":"/opt/stewardos/agent-configs/household-director","io":"/opt/stewardos/agent-configs/investment-officer","wellness":"/opt/stewardos/agent-configs/wellness-advisor"}

CODEX_BIN=/usr/local/bin/codex
CODEX_TIMEOUT_SECONDS=360
CODEX_SCRATCH_DIR=/tmp/family-office-mail-worker

SCHEDULED_BRIEFS_ENABLED=true
BRIEFING_TIMEZONE=America/New_York
SCHEDULE_RECIPIENTS=["owner1@example.com","owner2@example.com"]
COS_WEEKLY_RECIPIENTS=["owner1@example.com","owner2@example.com"]

DATABASE_URL=sqlite+aiosqlite:///./family_office_mail_worker.db
