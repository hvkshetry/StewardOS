[Unit]
Description=Family Office Mail Worker
After=network.target

[Service]
Type=simple
User=REPLACE_WITH_SYSTEM_USER
WorkingDirectory=/opt/stewardos/agents/family-office-mail-worker
Environment=PATH=/usr/local/bin:/usr/bin:/bin
ExecStart=/opt/stewardos/agents/family-office-mail-worker/.venv/bin/uvicorn src.main:app --host 127.0.0.1 --port 8312
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
