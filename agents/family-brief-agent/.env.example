# Family Brief Agent environment template
SERVICE_HOST=127.0.0.1
SERVICE_PORT=8300
LOG_LEVEL=INFO

GOOGLE_CREDENTIALS_PATH=.google-client.json
GOOGLE_TOKEN_PATH=.google-token.json
GOOGLE_PUBSUB_TOPIC=projects/your-project/topics/gmail-push

AGENT_EMAIL=agent.mailbox@example.com
FAMILY_EMAILS=["family.member1@example.com","family.member2@example.com"]

AGENT_CONFIG_DIR_FAMILY=/opt/stewardos/agent-configs/family
AGENT_CONFIG_DIR_PERSONAL_FINANCE=/opt/stewardos/agent-configs/personal-finance
AGENT_CONFIG_DIR_PERSONAL_ADMIN=/opt/stewardos/agent-configs/personal-admin

MEALIE_API_TOKEN=replace-with-mealie-api-token
GROCY_API_KEY=replace-with-grocy-api-key
OURA_CLIENT_ID=replace-with-oura-client-id
OURA_CLIENT_SECRET=replace-with-oura-client-secret
