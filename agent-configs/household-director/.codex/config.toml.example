model = "gpt-5.4"
model_reasoning_effort = "xhigh"
approval_policy = "on-request"

[mcp_servers.google-workspace-personal-ro]
command = "/path/to/stewardos/servers/google-workspace-mcp/.venv/bin/python"
args = ["main.py", "--single-user", "--read-only"]
cwd = "/path/to/stewardos/servers/google-workspace-mcp"
startup_timeout_sec = 60
env = { WORKSPACE_MCP_CREDENTIALS_DIR = "/path/to/stewardos/agent-configs/.shared-google-creds-personal-ro", USER_GOOGLE_EMAIL = "personal.user@example.com", WORKSPACE_MCP_PORT = "8018", GOOGLE_OAUTH_CLIENT_ID = "${GOOGLE_OAUTH_CLIENT_ID}", GOOGLE_OAUTH_CLIENT_SECRET = "${GOOGLE_OAUTH_CLIENT_SECRET}" }

[mcp_servers.google-workspace-agent-rw]
command = "/path/to/stewardos/servers/google-workspace-mcp/.venv/bin/python"
args = ["main.py", "--single-user", "--tools", "gmail"]
cwd = "/path/to/stewardos/servers/google-workspace-mcp"
startup_timeout_sec = 60
env = { WORKSPACE_MCP_CREDENTIALS_DIR = "/path/to/stewardos/agent-configs/.shared-google-creds-agent-rw", USER_GOOGLE_EMAIL = "agent.mailbox@example.com", WORKSPACE_MCP_PORT = "8019", GOOGLE_OAUTH_CLIENT_ID = "${GOOGLE_OAUTH_CLIENT_ID}", GOOGLE_OAUTH_CLIENT_SECRET = "${GOOGLE_OAUTH_CLIENT_SECRET}" }

[mcp_servers.mealie]
command = "uv"
args = ["run", "python", "src/server.py"]
cwd = "/path/to/stewardos/servers/mealie-mcp"
startup_timeout_sec = 45
env = { MEALIE_BASE_URL = "http://localhost:9925", MEALIE_API_KEY = "${MEALIE_API_KEY}" }

[mcp_servers.grocy]
command = "uv"
args = ["run", "python", "server.py"]
cwd = "/path/to/stewardos/servers/grocy-mcp"
startup_timeout_sec = 45
env = { GROCY_URL = "http://localhost:9283", GROCY_API_KEY = "${GROCY_API_KEY}" }

[mcp_servers.family-edu]
command = "uv"
args = ["run", "python", "server.py"]
cwd = "/path/to/stewardos/servers/family-edu-mcp"
startup_timeout_sec = 45

[mcp_servers.paperless]
command = "node"
args = ["build/index.js"]
cwd = "/path/to/stewardos/servers/paperless-mcp"
startup_timeout_sec = 45
env = { PAPERLESS_URL = "http://localhost:8223", API_KEY = "${PAPERLESS_TOKEN}" }
