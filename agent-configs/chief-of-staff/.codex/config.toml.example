model = "gpt-5.4"
model_reasoning_effort = "xhigh"
approval_policy = "on-request"
sandbox_mode = "workspace-write"

[sandbox_workspace_write]
network_access = true

[mcp_servers.google-workspace-personal-ro]
command = "/path/to/stewardos/servers/google-workspace-mcp/.venv/bin/python"
args = ["main.py", "--single-user", "--read-only"]
cwd = "/path/to/stewardos/servers/google-workspace-mcp"
startup_timeout_sec = 60
env = { WORKSPACE_MCP_CREDENTIALS_DIR = "/path/to/stewardos/agent-configs/.shared-google-creds-personal-ro", USER_GOOGLE_EMAIL = "personal.user@example.com", WORKSPACE_MCP_PORT = "8012", GOOGLE_OAUTH_CLIENT_ID = "${GOOGLE_OAUTH_CLIENT_ID}", GOOGLE_OAUTH_CLIENT_SECRET = "${GOOGLE_OAUTH_CLIENT_SECRET}" }

[mcp_servers.google-workspace-agent-rw]
command = "/path/to/stewardos/servers/google-workspace-mcp/.venv/bin/python"
args = ["main.py", "--single-user", "--tools", "gmail"]
cwd = "/path/to/stewardos/servers/google-workspace-mcp"
startup_timeout_sec = 60
env = { WORKSPACE_MCP_CREDENTIALS_DIR = "/path/to/stewardos/agent-configs/.shared-google-creds-agent-rw", USER_GOOGLE_EMAIL = "agent.mailbox@example.com", WORKSPACE_MCP_PORT = "8013", GOOGLE_OAUTH_CLIENT_ID = "${GOOGLE_OAUTH_CLIENT_ID}", GOOGLE_OAUTH_CLIENT_SECRET = "${GOOGLE_OAUTH_CLIENT_SECRET}" }

[mcp_servers.office-mcp]
command = "node"
args = ["/path/to/office-mcp/index.js"]

[mcp_servers.office-mcp.env]
OFFICE_MCP_MODE = "production"
TRANSPORT_TYPE = "stdio"

[mcp_servers.paperless]
command = "node"
args = ["build/index.js"]
cwd = "/path/to/stewardos/servers/paperless-mcp"
startup_timeout_sec = 45
env = { PAPERLESS_URL = "http://localhost:8223", API_KEY = "${PAPERLESS_TOKEN}" }

[mcp_servers.memos]
command = "uv"
args = ["run", "python", "server.py"]
cwd = "/path/to/stewardos/servers/memos-mcp"
env = { MEMOS_URL = "http://localhost:5230", MEMOS_API_TOKEN = "${MEMOS_API_TOKEN}" }

[mcp_servers.actual-budget]
command = "node"
args = ["/path/to/stewardos/servers/actual-mcp/build/index.js"]
cwd = "/path/to/stewardos/servers/actual-mcp"
startup_timeout_sec = 180
env = { ACTUAL_SERVER_URL = "http://localhost:5006", ACTUAL_PASSWORD = "${ACTUAL_PASSWORD}", ACTUAL_BUDGET_SYNC_ID = "${ACTUAL_BUDGET_SYNC_ID}", ACTUAL_DATA_DIR = "/tmp/actual-mcp-data" }

[mcp_servers.homebox]
command = "uv"
args = ["run", "python", "server.py"]
cwd = "/path/to/stewardos/servers/homebox-mcp"
env = { HOMEBOX_URL = "http://localhost:3100", HOMEBOX_USERNAME = "${HOMEBOX_USERNAME}", HOMEBOX_PASSWORD = "${HOMEBOX_PASSWORD}" }
