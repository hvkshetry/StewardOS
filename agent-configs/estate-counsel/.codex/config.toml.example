model = "gpt-5.4"
model_reasoning_effort = "xhigh"
approval_policy = "on-request"
sandbox_mode = "workspace-write"

[sandbox_workspace_write]
network_access = true

[mcp_servers.google-workspace-personal-ro]
command = "/path/to/stewardos/servers/google-workspace-mcp/.venv/bin/python"
args = ["main.py", "--single-user", "--read-only"]
cwd = "/path/to/stewardos/servers/google-workspace-mcp"
startup_timeout_sec = 60
env = { WORKSPACE_MCP_CREDENTIALS_DIR = "/path/to/stewardos/agent-configs/.shared-google-creds-personal-ro", USER_GOOGLE_EMAIL = "personal.user@example.com", WORKSPACE_MCP_PORT = "8014", GOOGLE_OAUTH_CLIENT_ID = "${GOOGLE_OAUTH_CLIENT_ID}", GOOGLE_OAUTH_CLIENT_SECRET = "${GOOGLE_OAUTH_CLIENT_SECRET}" }

[mcp_servers.google-workspace-agent-rw]
command = "/path/to/stewardos/servers/google-workspace-mcp/.venv/bin/python"
args = ["main.py", "--single-user", "--tools", "gmail"]
cwd = "/path/to/stewardos/servers/google-workspace-mcp"
startup_timeout_sec = 60
env = { WORKSPACE_MCP_CREDENTIALS_DIR = "/path/to/stewardos/agent-configs/.shared-google-creds-agent-rw", USER_GOOGLE_EMAIL = "agent.mailbox@example.com", WORKSPACE_MCP_PORT = "8015", GOOGLE_OAUTH_CLIENT_ID = "${GOOGLE_OAUTH_CLIENT_ID}", GOOGLE_OAUTH_CLIENT_SECRET = "${GOOGLE_OAUTH_CLIENT_SECRET}" }

[mcp_servers.estate-planning]
command = "uv"
args = ["run", "python", "server.py"]
cwd = "/path/to/stewardos/servers/estate-planning-mcp"

[mcp_servers.paperless]
command = "node"
args = ["build/index.js"]
cwd = "/path/to/stewardos/servers/paperless-mcp"
env = { PAPERLESS_URL = "http://localhost:8223", API_KEY = "${PAPERLESS_TOKEN}" }

[mcp_servers.household-tax]
command = "uv"
args = ["run", "python", "server.py"]
cwd = "/path/to/stewardos/servers/household-tax-mcp"

[mcp_servers.finance-graph]
command = "uv"
args = ["run", "python", "server.py"]
cwd = "/path/to/stewardos/servers/finance-graph-mcp"
