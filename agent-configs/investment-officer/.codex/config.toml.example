model = "gpt-5.3-codex"
model_reasoning_effort = "xhigh"
approval_policy = "on-request"
sandbox_mode = "workspace-write"

[sandbox_workspace_write]
network_access = true

[mcp_servers.google-workspace-personal-ro]
command = "/path/to/stewardos/servers/google-workspace-mcp/.venv/bin/python"
args = ["main.py", "--single-user", "--read-only"]
cwd = "/path/to/stewardos/servers/google-workspace-mcp"
startup_timeout_sec = 60
env = { WORKSPACE_MCP_CREDENTIALS_DIR = "/path/to/stewardos/agent-configs/.shared-google-creds-personal-ro", USER_GOOGLE_EMAIL = "personal.user@example.com", WORKSPACE_MCP_PORT = "8020", GOOGLE_OAUTH_CLIENT_ID = "${GOOGLE_OAUTH_CLIENT_ID}", GOOGLE_OAUTH_CLIENT_SECRET = "${GOOGLE_OAUTH_CLIENT_SECRET}" }

[mcp_servers.google-workspace-agent-rw]
command = "/path/to/stewardos/servers/google-workspace-mcp/.venv/bin/python"
args = ["main.py", "--single-user", "--tools", "gmail"]
cwd = "/path/to/stewardos/servers/google-workspace-mcp"
startup_timeout_sec = 60
env = { WORKSPACE_MCP_CREDENTIALS_DIR = "/path/to/stewardos/agent-configs/.shared-google-creds-agent-rw", USER_GOOGLE_EMAIL = "agent.mailbox@example.com", WORKSPACE_MCP_PORT = "8021", GOOGLE_OAUTH_CLIENT_ID = "${GOOGLE_OAUTH_CLIENT_ID}", GOOGLE_OAUTH_CLIENT_SECRET = "${GOOGLE_OAUTH_CLIENT_SECRET}" }

[mcp_servers.market-intel-direct]
command = "/path/to/stewardos/servers/investing-workspace/.venv/bin/python"
args = ["/path/to/stewardos/servers/investing-workspace/market-intel-direct/server.py"]
startup_timeout_sec = 60
env = { FRED_API_KEY = "${FRED_API_KEY}" }

[mcp_servers.sec-edgar]
command = "/path/to/stewardos/servers/investing-workspace/sec-edgar/.venv/bin/python"
args = ["/path/to/stewardos/servers/investing-workspace/sec-edgar/consolidated_server.py"]
cwd = "/path/to/stewardos/servers/investing-workspace/sec-edgar"
startup_timeout_sec = 120
env = { EDGAR_LOCAL_DATA_DIR = "/tmp/sec-edgar-data", EDGAR_CACHE_DIR = "/tmp/sec-edgar-cache" }

[mcp_servers.portfolio-analytics]
command = "/path/to/stewardos/servers/investing-workspace/.venv/bin/python"
args = ["/path/to/stewardos/servers/investing-workspace/portfolio-analytics/server.py"]
startup_timeout_sec = 90
env = { GHOSTFOLIO_URL = "http://localhost:8224", GHOSTFOLIO_TOKEN = "${GHOSTFOLIO_TOKEN}" }

[mcp_servers.policy-events]
command = "/path/to/stewardos/servers/investing-workspace/.venv/bin/python"
args = ["/path/to/stewardos/servers/investing-workspace/policy-events/server.py"]
startup_timeout_sec = 60
env = { PYTHONPATH = "/path/to/stewardos/servers/investing-workspace", CONGRESS_API_KEY = "${CONGRESS_API_KEY}", GOVINFO_API_KEY = "${GOVINFO_API_KEY}" }

[mcp_servers.household-tax]
command = "/path/to/stewardos/servers/household-tax-mcp/.venv/bin/python"
args = ["server.py"]
cwd = "/path/to/stewardos/servers/household-tax-mcp"
startup_timeout_sec = 120

[mcp_servers.ghostfolio]
command = "/path/to/stewardos/servers/ghostfolio-mcp/.venv/bin/python"
args = ["server.py"]
cwd = "/path/to/stewardos/servers/ghostfolio-mcp"
startup_timeout_sec = 120
env = { GHOSTFOLIO_URL = "http://localhost:8224", GHOSTFOLIO_TOKEN = "${GHOSTFOLIO_TOKEN}" }

[mcp_servers.finance-graph]
command = "uv"
args = ["run", "python", "server.py"]
cwd = "/path/to/stewardos/servers/finance-graph-mcp"
startup_timeout_sec = 120
env = { RENTCAST_BASE_URL = "https://api.rentcast.io/v1", RENTCAST_API_KEY = "${RENTCAST_API_KEY}" }

[mcp_servers.paperless]
command = "node"
args = ["build/index.js"]
cwd = "/path/to/stewardos/servers/paperless-mcp"
startup_timeout_sec = 45
env = { PAPERLESS_URL = "http://localhost:8223", API_KEY = "${PAPERLESS_TOKEN}" }
