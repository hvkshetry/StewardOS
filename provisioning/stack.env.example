# Core host settings
STEWARDOS_ROOT=/opt/stewardos
STEWARDOS_DOMAIN=example.com

# Database and service placeholders (replace locally)
POSTGRES_PASSWORD=replace-me
ESTATE_DB_PASSWORD=replace-me
FINANCE_DB_PASSWORD=replace-me

# OAuth placeholders (replace locally)
GOOGLE_OAUTH_CLIENT_ID=replace-me
GOOGLE_OAUTH_CLIENT_SECRET=replace-me

# Optional tunnel/edge placeholders
CLOUDFLARE_TUNNEL_TOKEN=replace-me
