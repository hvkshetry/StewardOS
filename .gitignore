# --- StewardOS: local runtime state and sensitive production files ---

# Codex runtime state (keep sanitized examples only)
agent-configs/**/.codex/**
!agent-configs/**/.codex/
!agent-configs/**/.codex/config.toml.example
agents/**/.codex/**
!agents/**/.codex/
!agents/**/.codex/config.toml.example

# Agent credential directories and shared OAuth artifacts
agent-configs/**/.google-creds-*/
agent-configs/.shared-google-creds-*/
agent-configs/.env.google-oauth

# Persona runtime outputs
agent-configs/**/output/
agent-configs/**/auth.json
agent-configs/**/config.toml
agent-configs/**/models_cache.json
agent-configs/**/version.json
agent-configs/**/.personality_migration
agent-configs/**/log/
agent-configs/**/skills/
agent-configs/**/.actual-mcp-data/

# Live env/config state
agents/**/.env
servers/**/.env
servers/**/.env.oauth21
servers/investing-workspace/.mcp.json
.claude/settings.local.json

# Local worker/database state
agents/family-office-mail-worker/family_office_mail_worker.db
servers/**/mcp_server_debug.log
servers/**/mealie_mcp_server.log
servers/**/.beads/
agents/*/*.service
!agents/*/*.service.example

# Ignore vendored upstream source directories in this repository.
# Use docs/upstreams + scripts/bootstrap_upstreams.sh to fetch pinned versions.
servers/actual-mcp/
servers/apple-health-mcp/
servers/google-workspace-mcp/
servers/mealie-mcp/
servers/oura-mcp/
servers/paperless-mcp/
servers/investing-workspace/sec-edgar/
servers/plane-fork/
servers/us-legal-mcp/

# Local one-off artifact from dependency probing
servers/household-tax-mcp/=6.4.0

